{
  "name": "pastecal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test": "bash test/smoke-llm.sh",
    "test:parser": "node --test test/parser.test.js",
    "test:parser:coverage": "c8 --include 'lib/**' --reporter=text --reporter=html node --test test/parser.test.js",
    "test:components": "vitest run --reporter=verbose",
    "test:components:coverage": "vitest run --coverage",
    "test:unit": "npm run test:parser && npm run test:components",
    "test:coverage": "npm run test:parser:coverage && npm run test:components:coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "c8": "^10.1.3",
    "chrono-node": "^2.9.0",
    "happy-dom": "^20.4.0",
    "jsdom": "^27.4.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.27"
  }
}
